{
  "name": "heritagevault-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @heritagevault/api\" \"npm run dev -w @heritagevault/web\"",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.2"
  }
}
